# ─────────────────────────────────────────────────────────────────────────────
# Alfred Core Service — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
APP_HOSTNAME=localhost
APP_PORT=8200

# ── Database ──────────────────────────────────────────────────────────────────
# Provider (only PostgreSQL is supported)
DB_PROVIDER=PostgreSQL

DB_HOST=localhost
DB_PORT=5432
DB_NAME=alfred_core
DB_USER=postgres
DB_PASSWORD=change_me

# EF Core diagnostics — enable only in Development
ENABLE_SENSITIVE_DATA_LOGGING=false
ENABLE_DETAILED_ERRORS=false

# ── Cache ─────────────────────────────────────────────────────────────────────
# Options: InMemory (default) | Redis
CACHE_PROVIDER=InMemory

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required when CACHE_PROVIDER=Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Gateway + Web UI)
CORS_ALLOWED_ORIGINS=https://gateway.test

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=alfred-storage
# R2_UPLOAD_URL_EXPIRATION_MINUTES=5
# R2_DOWNLOAD_URL_EXPIRATION_MINUTES=60
# R2_MAX_FILE_SIZE_BYTES=52428800
# R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ── mTLS (optional) ───────────────────────────────────────────────────────────
# Only required when running behind a service mesh with mutual TLS
MTLS_ENABLED=false
MTLS_SERVER_CERT_PATH=
MTLS_SERVER_CERT_PASSWORD=
MTLS_CA_CERT_PATH=
MTLS_HTTPS_PORT=8201
MTLS_ALLOW_HTTP=true
MTLS_HTTP_PORT=8200
