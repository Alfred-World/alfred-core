# ─────────────────────────────────────────────────────────────────────────────
# Alfred Core Service — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
APP_HOSTNAME=localhost
APP_PORT=8200

# ── Database ──────────────────────────────────────────────────────────────────
# Provider (only PostgreSQL is supported)
DB_PROVIDER=PostgreSQL

DB_HOST=localhost
DB_PORT=5432
DB_NAME=alfred_core
DB_USER=postgres
DB_PASSWORD=change_me

# EF Core diagnostics — enable only in Development
ENABLE_SENSITIVE_DATA_LOGGING=false
ENABLE_DETAILED_ERRORS=false

# ── Cache ─────────────────────────────────────────────────────────────────────
# Options: InMemory (default) | Redis
CACHE_PROVIDER=InMemory

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required when CACHE_PROVIDER=Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# Redis Stream for identity user replication (Core local user table cache)
IDENTITY_USER_STREAM_KEY=identity:user-events
IDENTITY_USER_STREAM_POLL_MS=2000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Gateway + Web UI)
CORS_ALLOWED_ORIGINS=https://gateway.test

# ── Cloudflare R2 Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=alfred
# R2_UPLOAD_URL_EXPIRATION_MINUTES=5
# R2_DOWNLOAD_URL_EXPIRATION_MINUTES=60
# R2_MAX_FILE_SIZE_BYTES=52428800
# R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf
# Cloudflare API token with "Account Analytics: Read" permission — used to query R2 storage metrics
# Leave empty to disable quota enforcement (uploads continue without checking)
CF_API_TOKEN=your_cloudflare_api_token
# Storage quota in bytes — default 10 GB (Cloudflare R2 free tier). Set to 0 to disable.
# R2_STORAGE_QUOTA_BYTES=10737418240

# ── mTLS (optional) ───────────────────────────────────────────────────────────
# Only required when running behind a service mesh with mutual TLS
MTLS_ENABLED=false
MTLS_SERVER_CERT_PATH=
MTLS_SERVER_CERT_PASSWORD=
MTLS_CA_CERT_PATH=
MTLS_HTTPS_PORT=8201
MTLS_ALLOW_HTTP=true
MTLS_HTTP_PORT=8200

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Comma-separated list of Groq API keys (round-robin rotation for free-tier accounts)
GROQ_API_KEYS=gsk_key1,gsk_key2

# Comma-separated list of models for text/function-calling 
# (auto-rotates when one model's token quota is exhausted)
GROQ_DEFAULT_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant

# Comma-separated list of models for vision/image analysis
# (auto-rotates when one model's token quota is exhausted)
GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct

# Optional settings (with defaults):
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_KEY_COOLDOWN_MINUTES=60
# GROQ_MODEL_COOLDOWN_MINUTES=60
# GROQ_MAX_RETRIES=3
# GROQ_TIMEOUT_SECONDS=30
