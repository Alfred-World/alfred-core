# Database Provider
DB_PROVIDER=PostgreSQL

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alfred_core
DB_USER=postgres
DB_PASSWORD=postgres

# Development Options (only enable in development)
DB_ENABLE_SENSITIVE_LOGGING=true
DB_ENABLE_DETAILED_ERRORS=true

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
APP_HOSTNAME=localhost
APP_PORT=8200

# CORS Settings (Gateway + Web UI)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:7000,http://localhost:7001

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=alfred-storage
# R2_UPLOAD_URL_EXPIRATION_MINUTES=5
# R2_DOWNLOAD_URL_EXPIRATION_MINUTES=60
# R2_MAX_FILE_SIZE_BYTES=52428800
# R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf
